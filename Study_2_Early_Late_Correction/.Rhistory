if (length(to_install)) install.packages(to_install)
lapply(pkgs, library, character.only = TRUE)
# ---- Load data ----
# Put performance.xlsx in your working directory or change the path below.
dat <- readxl::read_excel("performance.xlsx", sheet = "Sheet1") %>%
mutate(ID = factor(ID))
# ---- Define items and truth key (17 items: t1=6, t2=5, t3=6) ----
items <- c(paste0("t1_q",1:6), paste0("t2_q",1:5), paste0("t3_q",1:6))
truth <- c(rep(FALSE,6), rep(FALSE,5), FALSE, TRUE, TRUE, TRUE, FALSE, TRUE)
names(truth) <- items
# Column name helpers
s1 <- paste0("stage1_", items)
s2 <- paste0("stage2_", items)
s3 <- paste0("stage3_", items)
fu <- paste0("follow_up_", items)
# ---- Filter: keep participants with ANY follow-up response ----
dat <- dat %>%
filter(rowSums(across(all_of(fu), ~ !is.na(.))) > 0)
# ---- Ensure types; convert follow-up 1/0 to logical answers ----
dat <- dat %>%
mutate(
across(all_of(fu), ~ ifelse(is.na(.), NA, . == 1)),  # FU answers as TRUE/FALSE/NA
across(all_of(c(s1,s2,s3)), as.logical)               # S1–S3 already logical; enforce
)
# ---- Long -> wide per item per participant with answers by stage ----
long <- dat %>%
pivot_longer(
cols = matches("^(stage1|stage2|stage3|follow_up)_t[123]_q\\d+$"),
names_to   = c("Stage","Item"),
names_pattern = "^(stage1|stage2|stage3|follow_up)_(t\\d_q\\d+)$",
values_to  = "Ans"
) %>%
mutate(
Item = factor(Item, levels = items),
Task = factor(sub("_q\\d+$","", as.character(Item)), levels = c("t1","t2","t3"))
)
# Attach truth per item
truth_df <- tibble(Item = factor(items, levels = items), Truth = truth)
long <- long %>% left_join(truth_df, by = "Item")
# Spread stages back to columns and compute correctness
wide <- long %>%
pivot_wider(names_from = Stage, values_from = Ans) %>%
mutate(
S1c = stage1 == Truth,
S2c = stage2 == Truth,
S3c = stage3 == Truth,
FUc = if_else(is.na(follow_up), NA, follow_up == Truth)
)
# ---- Define Early vs Late and make analysis set ----
analysis <- wide %>%
filter(S1c == FALSE, (S2c | S3c), !is.na(FUc)) %>%      # S1 incorrect, corrected by S2 or S3, FU observed
mutate(
EarlyCorrected = as.integer(S2c == TRUE),             # 1 = early (correct by S2); 0 = late (only by S3)
Item = factor(Item), ID = factor(ID)
)
# ---- Descriptives: proportion correct at follow-up by Early/Late ----
desc <- analysis %>%
group_by(Label, EarlyCorrected) %>%
summarise(n = n(),
mean_FU_correct = mean(FUc),
.groups = "drop") %>%
mutate(Group = ifelse(EarlyCorrected==1,"Early-corrected (by S2)","Late-corrected (only by S3)")) %>%
select(Label, Group, n, mean_FU_correct)
print(desc)
# ---- Logistic mixed model ----
# If your dataset also has a Label column, it will be included automatically.
has_label <- "Label" %in% names(dat)
analysis$EarlyCorrected <- factor(analysis$EarlyCorrected, levels = c("1", "0"))
# if (has_label) {
#   fit <- glmer(FUc ~ EarlyCorrected * Label + Task + overall_accuracy_stage1 + (1|ID) + (1|Item),
#                data = analysis, family = binomial)
# } else {
#   fit <- glmer(FUc ~ EarlyCorrected + Task + (1|ID) + (1|Item),
#                data = analysis, family = binomial)
# }
fit <- glmer(FUc ~ EarlyCorrected * Label + Task + overall_accuracy_stage1 + (1|ID) + (1|Item),
data = analysis, family = binomial)
summary(fit)
# ---- Odds ratios (fixed effects) with 95% CIs ----
or_tab <- broom.mixed::tidy(fit, effects = "fixed", conf.int = TRUE, exponentiate = TRUE)
print(or_tab)
# ---- Save analysis dataset (optional) ----
write.csv(analysis, "retention_items_analysis.csv", row.names = FALSE)
cat("\nSaved per-item analysis data to retention_items_analysis.csv\n")
library(emmeans)
library(car)
aov <- Anova(fit, type = 3)
aov
library(parameters)
model_parameters(fit, exponentiate = TRUE)
emmeans(fit, pairwise ~ EarlyCorrected)
emmeans(fit, pairwise ~ Label * EarlyCorrected)
fit2 <- glmer(FUc ~ EarlyCorrected * Task * Label + (1|ID) + (1|Item),
data = analysis, family = binomial)
anova(fit, fit2)
performance::compare_performance(fit, fit2, rank = T)
emmeans(fit, pairwise ~ Label + EarlyCorrected)
emmeans(fit, Label + EarlyCorrected)
emmeans(fit, pairwise ~ Label + EarlyCorrected)
emmeans(fit, pairwise ~ Label)
emmeans(fit, pairwise ~ Label * EarlyCorrected)
knitr::opts_chunk$set(echo = TRUE)
