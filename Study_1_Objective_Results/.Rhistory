df_long <- df %>%
pivot_longer(
cols = c(Statistical_Accuracy, Clarity_and_Structure, Conceptual_Depth, Pedagogical_Effectiveness),
names_to = "Dimension",
values_to = "Rating"
)
df_long_tb <- df_long %>%
mutate(
ModelGroup = case_when(
grepl("ChatGPT_4o", Model, ignore.case = TRUE) ~ "Top",
grepl("ChatGPT_o1", Model, ignore.case = TRUE) ~ "Top",
grepl("Grok3", Model, ignore.case = TRUE) ~ "Bottom",
grepl("Gemini_2.0", Model, ignore.case = TRUE) ~ "Bottom",
TRUE ~ "Other"),
ModelGroup = factor(ModelGroup, levels = c("Top", "Bottom")))
TopBottom_comparison_overall <- df_long_tb %>%
group_by(ModelGroup) %>%
summarise(
Mean_Rating = mean(Rating, na.rm = TRUE),
SD_Rating = sd(Rating, na.rm = TRUE)
)
TopBottom_comparison_overall
df_long_tb_ins <- df_long_tb %>%
filter(Profession == "Student")
all_comparison <- df_long_tb_ins %>%
group_by(Model, Task) %>%
summarise(
Mean_Rating = mean(Rating, na.rm = TRUE),
SD_Rating = sd(Rating, na.rm = TRUE)
)
all_comparison
TopBottom_comparison <- df_long_tb %>%
group_by(Dimension, ModelGroup) %>%
summarise(
Mean_Rating = mean(Rating, na.rm = TRUE),
SD_Rating = sd(Rating, na.rm = TRUE)
)
overall_ttest <- t.test(Rating ~ ModelGroup, data = df_long_tb)
overall_ttest
cohen.d(df_long_tb$Rating, df_long_tb$ModelGroup)
dimensions_to_test <- c("Statistical_Accuracy", "Clarity_and_Structure", "Conceptual_Depth", "Pedagogical_Effectiveness")
# Loop through dimensions
results_list <- list()
for (dim in dimensions_to_test) {
df_temp <- df_long_tb %>%
filter(Dimension == dim)
# t-test
ttest_res <- t.test(Rating ~ ModelGroup, data = df_temp)
# Cohen's d
cohen_res <- cohen.d(df_temp$Rating, df_temp$ModelGroup)
# Store results
results_list[[dim]] <- list(
ttest = ttest_res,
cohen_d = cohen_res
)
# Optionally print or do something else
print(paste("Results for dimension:", dim))
print(ttest_res)
print(cohen_res)
}
RaterGroup_comparison <- df_long_tb %>%
group_by(Profession, Dimension, ModelGroup) %>%
summarise(
Mean_Rating = mean(Rating, na.rm = TRUE),
SD_Rating = sd(Rating, na.rm = TRUE)
)
RaterGroup_overall_comparison <- df_long_tb %>%
group_by(Profession, ModelGroup) %>%
summarise(
Mean_Rating = mean(Rating, na.rm = TRUE),
SD_Rating = sd(Rating, na.rm = TRUE),
N = n()
)
RaterGroup_overall_comparison
df_long_tb_top <- df_long_tb %>%
filter(ModelGroup == "Top")
prof_ttest <- t.test(Rating ~ Profession, data = df_long_tb_top)
prof_ttest
cohen.d(df_long_tb_top$Rating, df_long_tb_top$Profession)
df_long_tb_btm <- df_long_tb %>%
filter(ModelGroup == "Bottom")
prof_ttest <- t.test(Rating ~ Profession, data = df_long_tb_btm)
prof_ttest
cohen.d(df_long_tb_btm$Rating, df_long_tb_btm$Profession)
dimensions_to_test <- c("Statistical_Accuracy", "Clarity_and_Structure", "Conceptual_Depth", "Pedagogical_Effectiveness")
ttest_summary <- data.frame()
for (dim in dimensions_to_test) {
df_temp <- df_long_tb %>% filter(Dimension == dim)
ttest_res <- t.test(Rating ~ ModelGroup, data = df_temp)
cohen_res <- cohen.d(df_temp$Rating, df_temp$ModelGroup)
# Get mean and SD by group
mean_sd <- df_temp %>%
group_by(ModelGroup) %>%
summarise(
Mean_Rating = mean(Rating, na.rm = TRUE),
SD_Rating = sd(Rating, na.rm = TRUE)
)
# Combine into one row per dimension
result_row <- data.frame(
Dimension = dim,
Mean_Btm = mean_sd$Mean_Rating[2],
SD_Btm = mean_sd$SD_Rating[2],
Mean_Top = mean_sd$Mean_Rating[1],
SD_Top = mean_sd$SD_Rating[1],
t_statistic = ttest_res$statistic,
p_value = ttest_res$p.value,
cohens_d = cohen_res$estimate
)
ttest_summary <- bind_rows(ttest_summary, result_row)
}
writexl::write_xlsx(ttest_summary, "Results/Dimension_Comparison_By_Model.xlsx")
dimensions_to_test <- c("Statistical_Accuracy", "Clarity_and_Structure", "Conceptual_Depth", "Pedagogical_Effectiveness")
rater_to_test <- c("Student", "Instructor")
ttest_rater_summary <- data.frame()
for (dim in dimensions_to_test) {
for (rater in rater_to_test) {
df_temp <- df_long_tb %>%
filter(Dimension == dim, Profession == rater)
if (nrow(df_temp) < 3) next
ttest_res <- t.test(Rating ~ ModelGroup, data = df_temp)
cohen_res <- cohen.d(df_temp$Rating, df_temp$ModelGroup)
# Get mean and SD by ModelGroup
mean_sd <- df_temp %>%
group_by(ModelGroup) %>%
summarise(
Mean_Rating = mean(Rating, na.rm = TRUE),
SD_Rating = sd(Rating, na.rm = TRUE)
)
# Reorder ModelGroup to make sure rows are consistent (e.g., "Top", "Btm")
mean_sd <- mean_sd %>% arrange(ModelGroup)
result_row <- data.frame(
Dimension = dim,
Rater = rater,
Mean_Btm = mean_sd$Mean_Rating[2],
SD_Btm = mean_sd$SD_Rating[2],
Mean_Top = mean_sd$Mean_Rating[1],
SD_Top = mean_sd$SD_Rating[1],
t_statistic = ttest_res$statistic,
p_value = ttest_res$p.value,
cohens_d = cohen_res$estimate
)
ttest_rater_summary <- bind_rows(ttest_rater_summary, result_row)
}
}
write_xlsx(ttest_rater_summary, "Results/Dimension_Comparison_By_Rater.xlsx")
model_comparison <- df_long %>%
group_by(Model, Dimension) %>%
summarise(
Mean_Rating = mean(Rating, na.rm = TRUE),
SD_Rating = sd(Rating, na.rm = TRUE)
)
bruceR::export(model_comparison, file="Results/Model_Wise_Comparison.xlsx")
rater_model_comparison <- df_long %>%
group_by(Profession, Model) %>%
summarise(
Mean = mean(Rating, na.rm = TRUE),
SD = sd(Rating, na.rm = TRUE),
N = n(),
SE = SD/sqrt(N)
)
bruceR::export(rater_model_comparison, file="Results/Rater_Model_Wise_Comparison.xlsx")
model_task_comparison <- df_long %>%
group_by(Model, Task) %>%
summarise(
Mean = mean(Rating, na.rm = TRUE),
SD = sd(Rating, na.rm = TRUE),
N = n(),
SE = SD/sqrt(N)
)
bruceR::export(model_task_comparison, file="Results/Model_Task_Comparison.xlsx")
model_task_comparison <- df_long %>%
group_by(Profession, Model, Task, Dimension) %>%
summarise(
Mean = mean(Rating, na.rm = TRUE),
SD = sd(Rating, na.rm = TRUE),
N = n(),
SE = SD/sqrt(N)
)
